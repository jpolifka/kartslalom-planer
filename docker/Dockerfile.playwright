FROM mcr.microsoft.com/playwright:v1.61.1-noble
WORKDIR /app
COPY package.json ./
# npm install (kein ci) — package-lock.json enthält @playwright/test noch nicht,
# da das Paket erst via Dockerfile hinzugefügt wurde. Browser sind im Base-Image.
RUN npm install --ignore-scripts
COPY tsconfig.json playwright.config.ts tsconfig.e2e.json ./
COPY e2e/ ./e2e/
CMD ["npx", "playwright", "test", "--reporter=list"]
