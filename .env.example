# Kartslalom Streckenplaner — Umgebungsvariablen
#
# Entwicklung (lokal):
#   cp .env.example .env.local
#   VITE_SUPABASE_URL auf lokalen Supabase-Stack zeigen lassen (http://localhost:8000)
#
# Produktion (Server):
#   cp .env.example .env
#   VITE_SUPABASE_URL auf den eigenen self-hosted Stack zeigen lassen
#   (https://kartapi.cheezuscraizt.de), ANON_KEY aus docker/supabase/.env
#   -- kein Supabase-Cloud-Projekt mehr, siehe docs/build-und-deployment.md
#   docker compose -f docker/docker-compose.yml up -d --build

# Supabase-Verbindung
VITE_SUPABASE_URL=http://localhost:8000
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Nur fuer Produktion (docker/docker-compose.yml): Name des externen
# Docker-Netzwerks, ueber das der (containerisierte, repo-externe)
# nginx-Reverse-Proxy die App und Kong per Containername erreicht -- siehe
# docs/build-und-deployment.md. Muss vorher existieren
# (`docker network create kartslalom-edge` oder durch das Proxy-Projekt).
EDGE_NETWORK_NAME=kartslalom-edge
