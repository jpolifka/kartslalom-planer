    "react-router-dom": "^7.17.0",
    "svg2pdf.js": "^2.7.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
